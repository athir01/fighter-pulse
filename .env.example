# fighter-pulse environment variables — committed SHAPE only, never real secrets.
# Copy to .env.local and fill in real values.

# Postgres — local via `docker compose up -d`, or point at a hosted instance later.
DATABASE_URL=postgresql://fighterpulse:fighterpulse@localhost:5432/fighterpulse

# Anthropic — LLM disambiguation + sentiment scoring (Story: combined single-call scorer).
ANTHROPIC_API_KEY=sk-ant-your-key

# Hard ceiling on cumulative LLM spend across all runs. The pipeline halts new
# LLM calls once this is reached (see ingest/cost_tracker.py). Free VADER
# scoring is unaffected.
LLM_COST_CAP_USD=5.00

# Ingest tuning
INGEST_USER_AGENT=fighter-pulse/0.1 (+https://github.com/YOUR_USERNAME/fighter-pulse)
INGEST_RATE_LIMIT_RPS=1.0
